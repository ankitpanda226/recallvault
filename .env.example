# Copy to .env and edit as needed. All flags are optional — defaults are sensible.

# Storage root (default: ./storage relative to repo)
# RV_STORAGE_ROOT=/path/to/storage

# Embedding model (sentence-transformers name; downloaded on first use)
# RV_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval
# RV_TOP_K_SEMANTIC=5
# RV_RECENCY_HALF_LIFE_DAYS=30

# Guard thresholds
# RV_VERIFIED_CONFIDENCE_MIN=0.75
# RV_CAUTIOUS_SEMANTIC_MIN=0.45

# Fact extraction
# RV_LLM_EXTRACTION=0                 # set 1 to use LLM path (stub; wire your own)
# RV_MIN_EXTRACTION_CONFIDENCE=0.6

# Conflict strategy: newer_explicit_wins | ask_user
# RV_CONFLICT_STRATEGY=newer_explicit_wins
